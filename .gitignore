# 🗺️ GIS Local Management System - .gitignore

# 🔐 Environment variables (IMPORTANT)
.env
.env.*
!.env.example

# 🧱 Build outputs
dist/
build/
bin/
obj/
*.js
!.*.js

# 👤 User-specific files
*.user
*.suo
*.userosscache
*.sln.docstates

# 🧠 Visual Studio / VS Code
.vs/
.vscode/
*.code-workspace

# 🧪 Test results
TestResults/
coverage/
.nyc_output/

# 📦 Package managers
node_modules/
jspm_packages/
*.nupkg
packages/
.nuget/
.pnp/
.pnp.js

# 🗄️ Database / local files
*.mdf
*.ldf
*.db
*.sqlite
*.sqlite3
prisma/migrations/

# 📄 Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# 🧹 OS junk
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# 📦 Cache files
.cache/
.parcel-cache/
.turbo/

# 🔧 IDE
.idea/
*.swp
*.swo
*~

# 📊 Optional documentation (keep generated docs out if needed)
# docs/api/